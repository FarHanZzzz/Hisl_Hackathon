{
    "name": "hisl-hackathon-project",
    "version": "1.0.0",
    "description": "Full-stack application with Next.js frontend and FastAPI backend",
    "scripts": {
        "predev": "echo Preparing to start...",
        "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
        "dev:frontend": "cd frontend && npm run dev",
        "dev:backend": "node scripts/run-backend.js",
        "install:all": "node scripts/install-all.js"
    },
    "devDependencies": {
        "concurrently": "^8.2.2"
    }
}